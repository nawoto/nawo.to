---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';
import TabNavigation from '../components/TabNavigation.astro';
import YearlyArticleList from '../components/YearlyArticleList.astro';
import { sortArticlesByDate } from '../utils/content';
import { getTextUrl } from '../utils/url';

const texts = sortArticlesByDate(await getCollection('texts'));
---

<Layout title={`TEXTS | ${SITE.title}`}>
  <TabNavigation activeTab="texts" />
  <YearlyArticleList
    articles={texts}
    getArticleUrl={(_collection, slug) => getTextUrl(slug)}
    showBorder={true}
  />
</Layout>
